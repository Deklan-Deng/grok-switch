{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Switch",
  "version": "0.1.0",
  "identifier": "app.grokswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "Grok Switch",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Utility",
    "shortDescription": "Switch Grok Build CLI providers",
    "longDescription": "Unofficial local desktop tool to manage Grok Build CLI providers. Tokens stay on disk until you enable a provider and write config.toml.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
